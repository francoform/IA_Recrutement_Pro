# Configuration Supabase (OBLIGATOIRES)
# Obtenez ces valeurs depuis votre projet Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Configuration Email SMTP (OBLIGATOIRE)
# Mot de passe pour l'envoi d'emails via OVH
SMTP_PASSWORD=votre_mot_de_passe_smtp

# Configuration OpenAI (OBLIGATOIRE)
# Clé API OpenAI pour l'analyse de CV
OPENAI_API_KEY=sk-...

# Configuration Admin (OPTIONNEL)
# Mot de passe pour accéder aux analytics admin
ADMIN_PASSWORD=votre_mot_de_passe_admin

# Configuration N8N Webhook (OBLIGATOIRE)
# URL du webhook n8n pour l'analyse de CV
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://votre-instance-n8n.com/webhook/votre-webhook-id

# Instructions de configuration :
# 1. Copiez ce fichier vers .env.local
# 2. Remplacez toutes les valeurs par vos vraies clés
# 3. Ne commitez JAMAIS le fichier .env.local
# 4. Pour Coolify, ajoutez ces variables dans Environment Variables